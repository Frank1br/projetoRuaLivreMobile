<?xml version="1.0" encoding="utf-8"?>
<!--
    Permite tráfego HTTP cleartext em qualquer domínio. Necessário porque a
    API roda em HTTP no IP local da LAN, que muda conforme a rede em que o
    notebook está (casa, faculdade, hotspot). Em produção (release com
    HTTPS), trocar por uma política mais restrita.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true" />
</network-security-config>
